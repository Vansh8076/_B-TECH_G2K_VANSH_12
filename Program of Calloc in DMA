#include <stdio.h>
#include<stdlib.h>
int main() {
    int sum=0,i,n,*arr;
    printf("Number of elements: ");
    scanf("%d",&n);
    arr=(int *)calloc(n,sizeof(int) );
    if(arr==NULL){
        printf("The memory is not allocated ");
        return 1;
    }
    for (i=0;i<n;i++){
        printf("Enter elements: ", i+1 );
        scanf("%d",&arr[i]);
        sum += arr[i];
    }
    printf("The sum is = %d",sum);
    return 0;
}
