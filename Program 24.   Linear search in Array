#include <stdio.h>

int linearSearch(int array[], int n, int x) {
  for (int i = 0; i < n; i++) {
    if (array[i] == x) {
      return i; // Element found, return its index
    }
  }
  return -1; // Element not found
}

int main() {
  int array[] = {12, 23, 22, 10, 45};
  int x = 22; // The element to search for
  int n = sizeof(array) / sizeof(array[0]); // Calculate the number of elements

  // Call the linear search function
  int result = linearSearch(array, n, x);

  // Print the result
  if (result == -1) {
    printf("Element not found\n");
  } else {
    printf("Element found at index: %d\n", result);
    printf("Element found at position: %d\n", result + 1); // 1-based indexing
  }

  return 0;
}
