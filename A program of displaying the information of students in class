#include <stdio.h>
struct Student {
    int roll;
    char name[50];
};
int main() {
    struct Student s[100];
    int n, i;
    printf("Enter number of students: ");
    scanf("%d", &n);
    for(i = 0; i < n; i++) {
        printf("\nEnter details of student %d:\n", i + 1);
        printf("Roll number: ");
        scanf("%d", &s[i].roll);
        printf("Name: ");
        scanf("%s", s[i].name);
    }
    printf("\n    Student Information    \n");
    for(i = 0; i < n; i++) {
        printf("\nStudent %d:\n", i + 1);
        printf("Roll number: %d\n", s[i].roll);
        printf("Name: %s\n", s[i].name);
    }
    return 0;
}
