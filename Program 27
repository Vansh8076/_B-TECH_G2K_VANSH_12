#include <stdio.h>

int main() {
    int matrix[10][10];
    int i, j, m, n, sum = 0;
    printf("Enter the number of rows and columns of the matrix (m n):\\n");
    scanf("%d %d", &m, &n);
    if (m == n) {
        printf("Enter the elements of the matrix:\\n");
        for (i = 0; i < m; i++) {
            for (j = 0; j < n; j++) {
                scanf("%d", &matrix[i][j]);
            }
        }
        printf("The given matrix is:\\n");
        for (i = 0; i < m; i++) {
            for (j = 0; j < n; j++) {
                printf("%d\t", matrix[i][j]);
           }
            printf("\\n");
        }
        for (i = 0; i < m; i++) {
            sum = sum + matrix[i][i];
        }

        printf("\\nThe sum of the main diagonal elements is: %d\\n", sum);
    } else {
        printf("\\nThe given order is not a square matrix. Cannot calculate the main diagonal sum.\\n");
    }

    return 0;
}
