#include <stdio.h>
int linearsearch(int arr[],int n,int key){
    for(int i=0;i<n;i++){
        if(arr[i]==key){
            return i;
        }
    }
    return -1;
}
int main() {
    int arr[100],n,i,key;
   printf("Enter number of elements: ");
   scanf("%d",&n);
   printf("Enter elements: ");
   for(i=0;i<n;i++){
       scanf("%d",&arr[i]);
   }
   printf("Enter key : ");
   scanf("%d",&key);
   int result=linearsearch(arr,n,key);
   if(result !=-1){
       printf("Element found at index = %d",result);
   }else{
       printf("Element not found ");
   }
    return 0;
}
