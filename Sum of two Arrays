#include <stdio.h>

int main() {
    int size, i;
    printf("Enter the number of elements in the arrays: ");
    scanf("%d", &size);
    int arr1[size], arr2[size], sum_arr[size];
    printf("\nEnter elements for the first array:\n");
    for (i = 0; i < size; i++) {
        printf("Element %d: ", i + 1);
        scanf("%d", &arr1[i]);
    }
    printf("\nEnter elements for the second array:\n");
    for (i = 0; i < size; i++) {
        printf("Element %d: ", i + 1);
        scanf("%d", &arr2[i]);
    }
    for (i = 0; i < size; i++) {
        sum_arr[i] = arr1[i] + arr2[i];
    }
    printf("\nSum of corresponding elements:\n");
    for (i = 0; i < size; i++) {
        printf("%d ", sum_arr[i]);
    }
    printf("\n");

    return 0;
}
