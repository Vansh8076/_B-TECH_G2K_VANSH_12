#include <stdio.h>
int main() {
char operator;
float a,b,x;
printf("enter operator (+,-,*,/,):\n");
scanf("%c",& operator);
printf("enter a,b :\n");
scanf("%f %f",&a,&b);
switch(operator){
case '+':
x=a+b;
printf("%f ",x);
break;
case '-':
x=a-b;
printf("%f",x);
break;
case '*':
x=a*b;
printf("%f ",x);
break;
case '/':
if(b!=0){
x=a/b;
printf("x=%.2f ",x);
}
else {
printf("Error ! division by zero");
}
break;
default :
printf("invalid operator");
}
    return 0;
}
