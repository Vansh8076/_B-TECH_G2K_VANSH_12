#include <stdio.h>
int max_num(int arr[],int size){
    int max = arr[0];
    for(int i=1;i<size;i++){
        if(max<arr[i]){
            max= arr[i];
        }
    }
    return max;
}
int main() {
    int arr[8] = {2,5,6,7,8,9,111,85};
    int  result= max_num(arr,8);
    printf ("The max no. = %d",result);
}
